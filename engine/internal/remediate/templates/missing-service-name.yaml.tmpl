# Argus remediation: missing-service-name — {{.RuleID}} on "{{.Service}}"
# Generated by `argus remediate` — review before applying.
#
# PREFERRED FIX (do this instead if you own the workload): set
# OTEL_SERVICE_NAME=<name> (or resource attributes in the SDK) on the
# workload. This collector-side patch is a stopgap: it tags telemetry that
# arrives without a service.name so it stops scoring as "{{.Service}}",
# but it cannot know the real service identity.

processors:
  transform/argus_set_service_name_{{.SafeService}}:
    error_mode: ignore
    trace_statements:
      - context: resource
        statements:
          - set(attributes["service.name"], "REPLACE_WITH_REAL_SERVICE_NAME") where attributes["service.name"] == nil or attributes["service.name"] == ""
    metric_statements:
      - context: resource
        statements:
          - set(attributes["service.name"], "REPLACE_WITH_REAL_SERVICE_NAME") where attributes["service.name"] == nil or attributes["service.name"] == ""
    log_statements:
      - context: resource
        statements:
          - set(attributes["service.name"], "REPLACE_WITH_REAL_SERVICE_NAME") where attributes["service.name"] == nil or attributes["service.name"] == ""

# Add the processor to each affected pipeline, before batch:
# service:
#   pipelines:
#     traces:
#       processors: [transform/argus_set_service_name_{{.SafeService}}, batch]
