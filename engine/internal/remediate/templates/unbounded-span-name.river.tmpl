// Argus remediation: unbounded-span-name — {{.RuleID}} on "{{.Service}}"
{{- if .Cardinality}}
// ~{{.Cardinality}} distinct span names observed in the window.
{{- end}}
// Generated by `argus remediate` — review before applying.
//
// PREFERRED FIX: name spans after the route TEMPLATE ("GET /users/{id}"),
// never the concrete URL — most HTTP instrumentations have a setting for
// this. This patch normalizes the usual offenders (numeric IDs, UUIDs,
// long hex) at the collector so name cardinality stops exploding, at the
// cost of rewriting span names for everyone downstream.

otelcol.processor.transform "argus_normalize_span_names_{{.SafeService}}" {
  error_mode = "ignore"

  trace_statements {
    context    = "span"
    statements = [
      `replace_pattern(name, "[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}", "{uuid}")`,
      `replace_pattern(name, "[0-9a-fA-F]{16,}", "{hex}")`,
      `replace_pattern(name, "/[0-9]+", "/{id}")`,
    ]
  }

  output {
    traces = [otelcol.processor.batch.default.input]
  }
}
