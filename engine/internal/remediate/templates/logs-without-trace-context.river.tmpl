// Argus remediation: logs-without-trace-context — {{.RuleID}} on "{{.Service}}"
{{- if .RatioPct}}
// {{.RatioPct}} of observed log volume carried no trace_id.
{{- end}}
// Generated by `argus remediate` — review before applying.
//
// HONEST NOTE: a collector cannot invent trace context. The real fix is in
// the application: use the OTel logging bridge/appender for your runtime
// (e.g. Logback/Log4j OTel appender, logrus/zap otel hooks, Python
// LoggingHandler) so records inherit the active span context.
//
// The patch below covers ONE recoverable case: apps that already print the
// trace id as text in the log body (e.g. "trace_id=<32 hex>"). It promotes
// that value to the record's trace context so correlation works downstream.

otelcol.processor.transform "argus_recover_trace_id_{{.SafeService}}" {
  error_mode = "ignore"

  log_statements {
    context    = "log"
    statements = [
      `set(trace_id.string, ExtractPatterns(body, "trace_id=(?P<trace>[0-9a-f]{32})")["trace"]) where trace_id.string == "00000000000000000000000000000000" and IsMatch(body, "trace_id=[0-9a-f]{32}")`,
    ]
  }

  output {
    logs = [otelcol.processor.batch.default.input]
  }
}
