// Argus remediation: log-level-abuse — {{.RuleID}} on "{{.Service}}"
// Generated by `argus remediate` — review before applying.
//
// PREFERRED FIX: lower the logger level in the app's production config —
// debug logs that never leave the process cost nothing. This patch drops
// DEBUG-and-below records for production environments at the collector:
// it saves ingest cost but the data is gone; if you need DEBUG during an
// incident you must revert it or use a dynamic log-level endpoint.

otelcol.processor.filter "argus_drop_debug_prod_{{.SafeService}}" {
  error_mode = "ignore"

  logs {
    log_record = [
      `severity_number < SEVERITY_NUMBER_INFO and IsMatch(resource.attributes["deployment.environment.name"], "^prod")`,
    ]
  }

  output {
    logs = [otelcol.processor.batch.default.input]
  }
}
