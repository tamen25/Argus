// Argus remediation: high-cardinality-attribute — {{.RuleID}} on "{{.Service}}"
// Metric "{{.Metric}}", attribute "{{.Attribute}}"{{if .Cardinality}} (~{{.Cardinality}} distinct values observed){{end}}.
// Generated by `argus remediate` — review before applying.
//
// PREFERRED FIX: stop emitting the unbounded attribute at the source (SDK
// view/relabel), or aggregate it into bounded buckets. This patch drops the
// attribute at the collector — series stop growing, but the dimension is
// gone for everyone downstream. Deleting a dimension changes series
// identity; existing dashboards querying by "{{.Attribute}}" will break.

otelcol.processor.transform "argus_drop_high_cardinality_{{.SafeService}}" {
  error_mode = "ignore"

  metric_statements {
    context    = "datapoint"
    statements = [
      `delete_key(attributes, "{{.Attribute}}") where metric.name == "{{.Metric}}"`,
    ]
  }

  output {
    metrics = [otelcol.processor.batch.default.input]
  }
}
