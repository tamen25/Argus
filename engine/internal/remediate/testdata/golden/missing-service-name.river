// Argus remediation: missing-service-name — RES-005 on "unknown_service:java"
// Generated by `argus remediate` — review before applying.
//
// PREFERRED FIX (do this instead if you own the workload): set
// OTEL_SERVICE_NAME=<name> (or resource attributes in the SDK) on the
// workload. This collector-side patch is a stopgap: it tags telemetry that
// arrives without a service.name so it stops scoring as "unknown_service:java",
// but it cannot know the real service identity.
//
// Wire this processor between your OTLP receiver and the batch processor,
// scoped to the pipeline that carries the offending workload.

otelcol.processor.transform "argus_set_service_name_unknown_service_java" {
  error_mode = "ignore"

  trace_statements {
    context    = "resource"
    statements = [
      `set(attributes["service.name"], "REPLACE_WITH_REAL_SERVICE_NAME") where attributes["service.name"] == nil or attributes["service.name"] == ""`,
    ]
  }
  metric_statements {
    context    = "resource"
    statements = [
      `set(attributes["service.name"], "REPLACE_WITH_REAL_SERVICE_NAME") where attributes["service.name"] == nil or attributes["service.name"] == ""`,
    ]
  }
  log_statements {
    context    = "resource"
    statements = [
      `set(attributes["service.name"], "REPLACE_WITH_REAL_SERVICE_NAME") where attributes["service.name"] == nil or attributes["service.name"] == ""`,
    ]
  }

  output {
    metrics = [otelcol.processor.batch.default.input]
    logs    = [otelcol.processor.batch.default.input]
    traces  = [otelcol.processor.batch.default.input]
  }
}
