// Argus remediation: high-cardinality-attribute — MET-001 on "checkout"
// Metric "http_requests_total", attribute "user_id" (~48000 distinct values observed).
// Generated by `argus remediate` — review before applying.
//
// PREFERRED FIX: stop emitting the unbounded attribute at the source (SDK
// view/relabel), or aggregate it into bounded buckets. This patch drops the
// attribute at the collector — series stop growing, but the dimension is
// gone for everyone downstream. Deleting a dimension changes series
// identity; existing dashboards querying by "user_id" will break.

otelcol.processor.transform "argus_drop_high_cardinality_checkout" {
  error_mode = "ignore"

  metric_statements {
    context    = "datapoint"
    statements = [
      `delete_key(attributes, "user_id") where metric.name == "http_requests_total"`,
    ]
  }

  output {
    metrics = [otelcol.processor.batch.default.input]
  }
}
